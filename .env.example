# Polymarket Trading Bot — local dry-run defaults
# Safe by default: simulation only, no live wallet/API secrets required.

SIMULATION_MODE=true
BOT_API_KEY=dev-bot-key

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# FastAPI / CORS
CORS_ORIGINS_RAW=["http://localhost:3000","http://127.0.0.1:3000"]

# Strategy + risk tuning
CYCLE_INTERVAL=15
MARKET_REFRESH_INTERVAL=300
MAX_POSITION_SIZE=50
MAX_POSITIONS=10
DAILY_LOSS_LIMIT=100
MAX_DRAWDOWN_PCT=0.20
KELLY_FRACTION=0.25

# Airdrop score targets
MARKETS_TARGET=50
VOLUME_TARGET=10000

# Optional live-mode fields (leave blank for dry-runs)
PRIVATE_KEY=
API_KEY=
API_SECRET=
API_PASSPHRASE=
