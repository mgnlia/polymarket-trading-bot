# Polymarket Trading Bot — Environment Variables

# ── Trading Mode ──────────────────────────────────────────────────────────────
# Set to false for live trading (requires wallet keys below)
SIMULATION_MODE=true

# ── Wallet / API Keys (required for live mode) ────────────────────────────────
# PRIVATE_KEY=0x...
# API_KEY=your_polymarket_api_key
# API_SECRET=your_polymarket_api_secret
# API_PASSPHRASE=your_polymarket_api_passphrase

# ── Strategy Tuning ───────────────────────────────────────────────────────────
ARB_THRESHOLD=0.02
MM_SPREAD_MIN=0.03
MM_ORDER_SIZE=5.0
MOMENTUM_THRESHOLD=0.60
MAX_POSITION_SIZE=50.0
MAX_POSITIONS=10
DAILY_LOSS_LIMIT=100.0

# ── Airdrop Targets ───────────────────────────────────────────────────────────
MARKETS_TARGET=50
VOLUME_TARGET=10000.0

# ── Bot Timing ────────────────────────────────────────────────────────────────
CYCLE_INTERVAL=30
MARKET_REFRESH_INTERVAL=300

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://your-railway-backend.railway.app
